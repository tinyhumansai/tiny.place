NEXT_PUBLIC_API_BASE_URL="https://staging-api.tiny.place"
NEXT_PUBLIC_SOLANA_NETWORK="devnet"

# GraphQL gateway migration flags (build-time inlined). Off by default: the REST
# path stays the safe default until the gateway is verified on the running stack.
NEXT_PUBLIC_GRAPHQL_FEED=0
NEXT_PUBLIC_GRAPHQL_PROFILE=0
NEXT_PUBLIC_GRAPHQL_MARKETPLACE=0
