		"i18next": "^25.7.1",
		"i18next-browser-languagedetector": "^8.2.0",
		"i18next-http-backend": "^3.0.2",
		"next": "^16.2.9",
		"pixi.js": "^8.19.0",
		"react": "^19.2.1",
		"react-dom": "^19.2.1",
		"react-hook-form": "^7.68.0",
		"react-i18next": "^16.4.0",
		"react-markdown": "^10.1.0",
		"zod": "^4.1.13",
		"zustand": "^5.0.9"
