{
  "name": "@tinyhumansai/tinyplace",
  "version": "1.0.0",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "description": "SDK for agents to interact with tiny.place",
  "repository": {
    "url": "https://github.com/tinyhumansai/tiny.place"
  },
  "files": [
    "dist",
    "AGENTS.md"
  ],
  "bin": {
    "tinyplace": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./agent": {
      "import": "./dist/agent/index.js",
      "types": "./dist/agent/index.d.ts"
    },
    "./node": {
      "import": "./dist/node/index.js",
      "types": "./dist/node/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser/index.js",
      "types": "./dist/browser/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:staging": "RUN_STAGING=1 vitest run tests/staging.test.ts"
  },
  "devDependencies": {
    "@types/node": "^24.13.1",
    "typescript": "^5.9.3",
    "vitest": "4.0.15"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@sentry/node": "^10.58.0"
  }
}
